# =============================================
# WILDORA — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your values

# --- SHOPIFY STOREFRONT API ---
# 1. In your Shopify Admin → Settings → Apps & sales channels → Develop apps
# 2. Create a custom app, name it "Wildora Headless"
# 3. Under "API credentials" → configure Storefront API scopes:
#    - unauthenticated_read_product_listings
#    - unauthenticated_write_checkouts
#    - unauthenticated_read_checkouts
#    - unauthenticated_write_customers
#    - unauthenticated_read_customer_tags

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_access_token

# --- GOOGLE ANALYTICS 4 ---
# From: Google Analytics → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- GOOGLE ADS CONVERSION TRACKING ---
# From: Google Ads → Tools → Conversions → Create conversion action
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ADD_TO_CART_LABEL=XXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CHECKOUT_LABEL=XXXXXXXXXXXXXXXXXXX

# --- SITE URL ---
NEXT_PUBLIC_SITE_URL=https://wildora.com
